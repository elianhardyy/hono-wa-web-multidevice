{
  "name": "whatsapp-status-app",
  "license": "CC-BY-NC-ND-4.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:client && tsx watch src/index.ts",
    "build:client": "esbuild src/frontend/client/history-table.tsx --bundle --outfile=public/assets/history-table.js --format=esm --jsx=automatic --jsx-import-source=react && esbuild src/frontend/client/ai-chat.tsx --bundle --outfile=public/assets/ai-chat.js --format=esm --jsx=automatic --jsx-import-source=react",
    "build": "npm run build:client && tsc",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@tanstack/ai": "^0.14.0",
    "@tanstack/ai-anthropic": "^0.8.2",
    "@tanstack/ai-gemini": "^0.10.0",
    "@tanstack/ai-openai": "^0.8.2",
    "@tanstack/ai-react": "^0.8.0",
    "@tanstack/react-table": "^8.21.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-loading-skeleton": "^3.5.0",
    "uuid": "^14.0.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
